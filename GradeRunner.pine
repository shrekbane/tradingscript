//@version=6
indicator("GradeRunner (Trend+Momentum+Vol+HTF)", shorttitle="GradeRunner", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=50)

// =========================================================================
// A from-scratch, independently built confluence/scalping indicator inspired
// by the general concept shown (multi-factor score, graded signal, auto
// entry/SL/3 TPs). This is NOT a copy of any specific author's source code
// (which is private/invite-only and was never seen) - it's a clean-room
// reimplementation of the described mechanics.
// =========================================================================

// ---------------- INPUTS ----------------
grpTrend = "Trend"
fastLen   = input.int(9,  "Fast EMA", group=grpTrend)
slowLen   = input.int(21, "Slow EMA", group=grpTrend)
htfTF     = input.timeframe("60", "Higher Timeframe Bias", group=grpTrend)

grpMom = "Momentum / Strength"
rsiLen   = input.int(14, "RSI Length", group=grpMom)
adxLen   = input.int(14, "ADX / DMI Length", group=grpMom)
macdFast = input.int(12, "MACD Fast", group=grpMom)
macdSlow = input.int(26, "MACD Slow", group=grpMom)
macdSig  = input.int(9,  "MACD Signal", group=grpMom)

grpVol = "Volatility"
atrLen    = input.int(14, "ATR Length", group=grpVol)
atrSmaLen = input.int(50, "ATR Average Length (for Low/Normal/High)", group=grpVol)

// Support/Resistance polarity-flip confirmation. Tracks recent swing
// pivots, watches for a "flip" (old resistance broken -> becomes a support
// candidate = RBS; old support broken -> becomes a resistance candidate =
// SBR), and can require a reject at that flipped zone before a signal is
// actually allowed to fire — see the "S/R Diagnostics" section further down
// for the zone-tracking logic itself, and the "S/R FLIP REJECT CONFIRMATION"
// block near the signal trigger for how the gate delays entry.
grpSR = "S/R Confirmation"
srPivotLen = input.int(5, "Pivot Lookback (bars each side)", minval=1, group=grpSR)
srShowZones = input.bool(true, "Plot S/R Zone Lines on Chart", group=grpSR)
// On by default: validated across enough real setups (consistent RBS/SBR
// rejects right after the signals that actually confirmed) to trust as the
// default behavior now, rather than opt-in.
srGateOn = input.bool(true, "Require S/R Flip Reject to Confirm Entry", group=grpSR)
srConfirmBars = input.int(10, "Confirmation Window (bars)", minval=1, group=grpSR, active=srGateOn)
// Purely visual, no effect on scoring/gating — supports the manual "look for a
// rejection candle at the zone" step from the signal checklist (see README),
// since that's a judgment call meant to be eyeballed on the chart, not
// automated. On by default so it's visible without extra setup.
srShowEngulf = input.bool(true, "Show Engulfing Candle Markers", group=grpSR)

grpSignal = "Signal / Risk"
minGradeInput = input.string("B", "Minimum Grade to Show Signal", options=["C","B","A","A+"], group=grpSignal)
slMult  = input.float(1.0, "Stop Loss (x ATR)", step=0.1, group=grpSignal)
tp1Mult = input.float(2.0, "TP1 (x ATR)", step=0.1, group=grpSignal)
tp2Mult = input.float(3.0, "TP2 (x ATR)", step=0.1, group=grpSignal)
tp3Mult = input.float(4.0, "TP3 (x ATR)", step=0.1, group=grpSignal)
extendBars = input.int(20, "Extend Lines (bars)", group=grpSignal)

// Structure-based SL/TP: instead of a fixed ATR distance, place the stop
// just beyond the nearest swing point behind entry, and targets at the next
// swing points ahead of entry. Off by default — untested against real
// charts yet, unlike the S/R confirmation gate above, which was validated
// against real setups before being turned on. Each level (SL/TP1/TP2/TP3)
// falls back to its ATR-based distance independently whenever no swing
// point qualifies (too close, too far, or none available at all), so a
// setup with poor nearby structure still gets a usable, tradeable level
// rather than being left blank.
useStructureSLTP = input.bool(false, "Use Structure-Based SL/TP (fallback to ATR)", group=grpSignal)
srSLTPMinGapMult = input.float(0.5, "Min Level Distance (x ATR)", step=0.1, minval=0.1, group=grpSignal, active=useStructureSLTP)
srSLTPMaxGapMult = input.float(8.0, "Max Level Distance (x ATR)", step=0.5, minval=1.0, group=grpSignal, active=useStructureSLTP)

// Core Signal: an extra, stricter gate on top of the confluence score. The
// score can flip direction purely because a lagging indicator crossed, with
// no real price action behind it. When enabled, a signal additionally needs
// a genuine breakout confirmation — price closing beyond the recent N-bar
// high/low in the signal's direction — before it's allowed to fire. This
// turns the score into a quality/grade filter and Core Signal into the
// actual trigger/timing mechanism.
coreSignalOn  = input.bool(false, "Core Signal (require breakout confirmation)", group=grpSignal)
// v6's active= greys out this input in the settings panel whenever Core
// Signal is off, since it does nothing until that toggle is on.
coreLookback  = input.int(5, "Core Signal Lookback (bars)", minval=1, group=grpSignal, active=coreSignalOn)

// Volatility scaling: SL/TP distances (in ATR multiples) get multiplied by
// one of these depending on the current Low/Normal/High volatility read, so
// stops/targets widen automatically when the market's noisier and tighten
// when it's calmer, instead of using one fixed distance regardless of
// conditions.
useVolScaling = input.bool(true, "Scale SL/TP by Volatility", group=grpSignal)
lowVolFactor  = input.float(0.75, "Low Volatility Multiplier",  step=0.05, group=grpSignal, active=useVolScaling)
highVolFactor = input.float(1.5,  "High Volatility Multiplier", step=0.05, group=grpSignal, active=useVolScaling)

// One-trade-at-a-time gate: while ON (default), a new signal can only
// override the currently tracked setup once that setup has hit TP1 (locked
// in first profit) or SL (stopped out). Before that point, new signals are
// simply ignored and the ongoing trade is left to run toward TP2/TP3. While
// OFF, any qualifying signal always overrides immediately, regardless of
// how far the current trade has progressed (the original behavior).
lockUntilTP1OrSL = input.bool(true, "Lock New Signals Until TP1 or SL Hit", group=grpSignal)

// Alert Hours: restricts when alert()/alertcondition() are allowed to fire —
// e.g. skip the Asian session, or only alert during your own trading hours.
// This only gates alerts. The score, badge, table, and drawn levels keep
// updating normally around the clock; nothing here suppresses the chart.
grpHours = "Alert Hours"
restrictAlertHours = input.bool(false, "Only Alert During Selected Hours", group=grpHours)
// input.session() opens TradingView's own session picker, which includes a
// day-of-week selector — no separate "which days" input needed.
alertSession = input.session("0900-1700", "Trading Hours (session)", group=grpHours, active=restrictAlertHours)

// Dropdown instead of free text — most people don't know their IANA
// timezone string off the top of their head. "Exchange (default)" maps to
// blank, which tells time() to use the chart symbol's own exchange timezone.
// Note: input.string()'s options list must be written inline like this —
// Pine doesn't allow assigning the [...] literal to a variable first.
alertTimezoneSel = input.string("Exchange (default)", "Timezone", options=["Exchange (default)", "UTC", "New York (UTC-5/-4)", "Chicago (UTC-6/-5)", "Los Angeles (UTC-8/-7)", "Sao Paulo (UTC-3)", "London (UTC+0/+1)", "Paris / Frankfurt (UTC+1/+2)", "Moscow (UTC+3)", "Dubai (UTC+4)", "Mumbai (UTC+5:30)", "Singapore (UTC+8)", "Hong Kong (UTC+8)", "Shanghai (UTC+8)", "Tokyo (UTC+9)", "Sydney (UTC+10/+11)", "Auckland (UTC+12/+13)"], group=grpHours, active=restrictAlertHours)

tzToIANA(sel) =>
    sel == "UTC" ? "UTC" :
     sel == "New York (UTC-5/-4)" ? "America/New_York" :
     sel == "Chicago (UTC-6/-5)" ? "America/Chicago" :
     sel == "Los Angeles (UTC-8/-7)" ? "America/Los_Angeles" :
     sel == "Sao Paulo (UTC-3)" ? "America/Sao_Paulo" :
     sel == "London (UTC+0/+1)" ? "Europe/London" :
     sel == "Paris / Frankfurt (UTC+1/+2)" ? "Europe/Paris" :
     sel == "Moscow (UTC+3)" ? "Europe/Moscow" :
     sel == "Dubai (UTC+4)" ? "Asia/Dubai" :
     sel == "Mumbai (UTC+5:30)" ? "Asia/Kolkata" :
     sel == "Singapore (UTC+8)" ? "Asia/Singapore" :
     sel == "Hong Kong (UTC+8)" ? "Asia/Hong_Kong" :
     sel == "Shanghai (UTC+8)" ? "Asia/Shanghai" :
     sel == "Tokyo (UTC+9)" ? "Asia/Tokyo" :
     sel == "Sydney (UTC+10/+11)" ? "Australia/Sydney" :
     sel == "Auckland (UTC+12/+13)" ? "Pacific/Auckland" :
     "" // "Exchange (default)" falls through to blank

alertTimezone = tzToIANA(alertTimezoneSel)

grpTable = "Display"
showTable = input.bool(true, "Show Info Table", group=grpTable)
showLabels = input.bool(true, "Show Signal Markers", group=grpTable)
showTrendLines = input.bool(false, "Show Trend (EMA) Lines", group=grpTable)
showHistory = input.bool(false, "Show Previous Setups (keep history)", group=grpTable)
maxSetups   = input.int(5, "Max Setups to Keep (if history on)", minval=1, maxval=40, group=grpTable, active=showHistory)
showGradeStats = input.bool(true, "Show Grade Win-Rate Stats", group=grpTable)
// Applies to both tables (info table and grade stats), so it only greys out
// when both are off — checking showTable alone would incorrectly grey this
// out whenever just the info table was hidden but stats were still shown.
tableSizeInput = input.string("Small", "Table Text Size", options=["Tiny","Small","Normal","Large"], group=grpTable, active=showTable or showGradeStats)
tableSize = tableSizeInput == "Tiny" ? size.tiny : tableSizeInput == "Normal" ? size.normal : tableSizeInput == "Large" ? size.large : size.small

// ---------------- COLOR PALETTE (light/dark theme safe) ----------------
// A Blade Runner-inspired reskin — neon cyan/magenta/violet in place of
// TradingView's stock teal/red, chosen as mid-brightness hex values (same
// approach as before) so nothing washes out or vanishes on either theme:
// - palBull/palBear: neon cyan-teal / neon magenta-pink. Keeps the same
//   "cool = bullish, warm/alarm = bearish" convention as before (still
//   intuitively reads as buy/sell) just recolored away from stock
//   teal/red into something distinctly neon.
// - palNeutral: derived from chart.fg_color, so it's automatically near-black
//   on a light chart and near-white on a dark chart — used for the TP levels,
//   which should read as "neutral text," not bullish or bearish.
// - palEntry: electric violet — holds contrast on both themes, distinct
//   from the bull/bear hues.
// - palEmaFast/palEmaSlow: amber/deep violet for the optional EMA lines —
//   amber/teal is Blade Runner's signature color-grading pair.
palBull    = color.new(#00B8D9, 0)
palBear    = color.new(#FF3D81, 0)
palEntry   = color.new(#7C4DFF, 0)
palNeutral = color.new(chart.fg_color, 0)
palEmaFast = color.new(#FFB300, 0)
palEmaSlow = color.new(#9D4EDD, 0)

// ---------------- TREND ----------------
emaFast = ta.ema(close, fastLen)
emaSlow = ta.ema(close, slowLen)
trendBull = emaFast > emaSlow

// Higher timeframe bias (confirmed HTF bars only -> no intrabar repaint)
htfEmaFast = request.security(syminfo.tickerid, htfTF, ta.ema(close, fastLen), lookahead=barmerge.lookahead_off)
htfEmaSlow = request.security(syminfo.tickerid, htfTF, ta.ema(close, slowLen), lookahead=barmerge.lookahead_off)
htfBull = htfEmaFast > htfEmaSlow

// Hard gate (not just a scored factor): a signal is only allowed to fire in
// the direction the higher timeframe already agrees with — unconditionally,
// at every grade, including A/A+. HTF Bias already contributes points to the
// score above, but that alone doesn't stop a signal from firing against it;
// a sharp local bounce candle can score high enough to hit A/A+ on its own
// while still fighting the bigger-picture trend. This gate is specifically
// about blocking that "buy/sell the bounce against the trend" trade type,
// not about maximizing win rate — a genuinely good counter-trend reversal
// signal getting blocked here is an accepted trade-off for the discipline.
htfTrendOk(dir) => (dir == 1 and htfBull) or (dir == -1 and not htfBull)

// ---------------- MOMENTUM ----------------
rsiVal = ta.rsi(close, rsiLen)
[macdLine, macdSignal, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)

// Hard gate, same posture as htfTrendOk above: a signal is only allowed to
// fire in the direction MACD Histogram already agrees with — unconditionally,
// at every grade. Prompted by checking factor diagnostics across several real
// B-grade setups: every one had MACD fully opposed (contributing zero to the
// winning side) while Local Trend/HTF Bias/ADX were all maxed in agreement —
// i.e. the "bigger picture" lined up but the most immediate momentum read
// hadn't actually turned yet. Every A+/A example checked already had MACD
// fully agreeing naturally, without this gate, so it's not expected to cost
// much at the top end. MACD Histogram is scored as a flat binary (2 or 0,
// no partial credit), so this is a plain agree/disagree check, not a
// configurable minimum-strength threshold.
macdOk(dir) => (dir == 1 and macdHist > 0) or (dir == -1 and macdHist < 0)

// ---------------- TREND STRENGTH (DMI/ADX) ----------------
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
adxStrong = adxVal > 20
diBull = diPlus > diMinus

// ---------------- VOLATILITY ----------------
atrVal    = ta.atr(atrLen)
atrAvg    = ta.sma(atrVal, atrSmaLen)
volRatio  = atrVal / atrAvg
volState  = volRatio >= 1.2 ? "High" : volRatio <= 0.8 ? "Low" : "Normal"

// Multiplier applied on top of the SL/TP ATR multiples below, based on volState.
volFactor = not useVolScaling ? 1.0 : volState == "High" ? highVolFactor : volState == "Low" ? lowVolFactor : 1.0

// ---------------- S/R POLARITY-FLIP TRACKING (diagnostics only) ----------------
// Tracks the most recent confirmed swing high/low as a candidate zone. Once
// price closes through it, the zone "flips" (old resistance becomes a support
// candidate = RBS, old support becomes a resistance candidate = SBR) and we
// watch for a retest: price wicking back into the zone but closing back away
// from it (a reject, not a reclaim). Each reject is emitted as its own event
// on that bar — same "let the user eyeball the count" approach as the
// engulfing check — rather than requiring N rejects before emitting anything.
// This is a single-zone-at-a-time simplification (not a history of every past
// pivot) to keep the first pass simple and avoid the complexity that sank the
// earlier "Avoid Entries Near Support/Resistance" feature. Purely additive:
// does not touch scoring, gating, or signal timing.
zoneTol = atrVal * 0.25

pivotHigh = ta.pivothigh(srPivotLen, srPivotLen)
pivotLow  = ta.pivotlow(srPivotLen, srPivotLen)

// Rolling history of recent swing points (separate from resZone/supZone
// above, which only ever track the single latest one). Feeds the
// Structure-Based SL/TP option below — that feature needs multiple past
// levels at different distances (nearest for SL/TP1, further out for
// TP2/TP3), not just the most recent pivot in each direction. Capped at
// srMaxSwings entries each so the arrays don't grow unbounded over a long
// chart history.
srMaxSwings = 30
var float[] swingHighs = array.new_float()
var float[] swingLows  = array.new_float()
if not na(pivotHigh)
    array.push(swingHighs, pivotHigh)
    if array.size(swingHighs) > srMaxSwings
        array.shift(swingHighs)
if not na(pivotLow)
    array.push(swingLows, pivotLow)
    if array.size(swingLows) > srMaxSwings
        array.shift(swingLows)

var float resZone    = na // last confirmed pivot high (candidate resistance, or flipped-support once broken)
var bool  resBroken  = false
var float supZone    = na // last confirmed pivot low (candidate support, or flipped-resistance once broken)
var bool  supBroken  = false

if not na(pivotHigh)
    resZone := pivotHigh
    resBroken := false
if not na(pivotLow)
    supZone := pivotLow
    supBroken := false

// Confirmed close through a zone flips it.
if not na(resZone) and not resBroken and close > resZone
    resBroken := true
if not na(supZone) and not supBroken and close < supZone
    supBroken := true

// RBS: old resistance (resZone), now flipped to support. A reject is a bar
// that wicks down into the zone but still closes back above it.
rbsReject = resBroken and not na(resZone) and low <= resZone + zoneTol and close > resZone
// A confirmed close back below the zone invalidates the flip (real breakdown,
// not a reject) — re-arm so we stop signaling rejects at a level that failed.
if resBroken and not na(resZone) and close < resZone
    resBroken := false

// SBR: old support (supZone), now flipped to resistance. A reject is a bar
// that wicks up into the zone but still closes back below it.
sbrReject = supBroken and not na(supZone) and high >= supZone - zoneTol and close < supZone
if supBroken and not na(supZone) and close > supZone
    supBroken := false

srSignal = rbsReject ? 1 : sbrReject ? -1 : 0

// Optional visual of the tracked zones themselves, since a single Data Window
// number on the reject bar doesn't show what zone it's referring to. Off by
// default so it doesn't clutter the chart unless you're actively reviewing
// this feature. Color reflects current role: resZone drawn palBear while
// still untested resistance, palBull once flipped to (candidate) support —
// and mirrored for supZone.
plot(srShowZones ? resZone : na, "S/R: Resistance/Flipped-Support Zone", color=resBroken ? palBull : palBear, style=plot.style_circles, linewidth=1)
plot(srShowZones ? supZone : na, "S/R: Support/Flipped-Resistance Zone", color=supBroken ? palBear : palBull, style=plot.style_circles, linewidth=1)

// ---------------- CONFLUENCE SCORE (0-10, split bull/bear) ----------------
// Each factor's bull/bear points are named (not just inlined into
// bullPts/bearPts) so they can be exposed individually as Data Window
// diagnostics below — lets a past signal's grade actually be explained
// after the fact, instead of only showing the final badge.
bullPts = 0.0
bearPts = 0.0

// 1) Local trend (2 pts)
trendBullPts = trendBull ? 2.0 : 0.0
trendBearPts = trendBull ? 0.0 : 2.0
bullPts += trendBullPts
bearPts += trendBearPts

// 2) HTF bias (2 pts)
htfBullPts = htfBull ? 2.0 : 0.0
htfBearPts = htfBull ? 0.0 : 2.0
bullPts += htfBullPts
bearPts += htfBearPts

// 3) RSI momentum (up to 2 pts, scaled by distance from 50)
rsiBullPts = rsiVal > 50 ? math.min((rsiVal - 50) / 25 * 2, 2.0) : 0.0
rsiBearPts = rsiVal < 50 ? math.min((50 - rsiVal) / 25 * 2, 2.0) : 0.0
bullPts += rsiBullPts
bearPts += rsiBearPts

// 4) MACD histogram direction (2 pts)
macdBullPts = macdHist > 0 ? 2.0 : 0.0
macdBearPts = macdHist > 0 ? 0.0 : 2.0
bullPts += macdBullPts
bearPts += macdBearPts

// 5) ADX/DMI strength confirmation (2 pts, only if trend is strong)
// Declared (defaulting to 0.0) before the if block, not just inside it, so
// they're readable outside that scope for the diagnostics below — behavior
// is identical, since they still land on 0.0 whenever adxStrong is false.
adxBullPts = 0.0
adxBearPts = 0.0
if adxStrong
    adxBullPts := diBull ? 2.0 : 0.0
    adxBearPts := diBull ? 0.0 : 2.0
bullPts += adxBullPts
bearPts += adxBearPts

score     = math.max(bullPts, bearPts)
direction = bullPts > bearPts ? 1 : bullPts < bearPts ? -1 : 0

gradeOf(s) =>
    s >= 9.0 ? "A+" : s >= 7.0 ? "A" : s >= 5.0 ? "B" : "C"

grade = gradeOf(score)

gradeRank(g) => g == "A+" ? 4 : g == "A" ? 3 : g == "B" ? 2 : 1
passesFilter = gradeRank(grade) >= gradeRank(minGradeInput)

starsOf(g) =>
    g == "A+" ? "★★★" : g == "A" ? "★★" : g == "B" ? "★" : ""
stars = starsOf(grade)

// Pip size varies by instrument, and there's no single Pine builtin for it —
// syminfo.mintick is the smallest price increment, not necessarily a pip
// (e.g. 5-decimal EURUSD quotes have a mintick 1/10th the size of a real
// pip). Broker-style convention used here: 0.0001 for standard forex pairs
// (0.01 for JPY pairs, which quote two decimals fewer), 0.01 for XAUUSD (a
// common gold convention where 100 pips = $1), and 1.0 for crypto — that
// last one is a rough, non-standard approximation (crypto doesn't really
// use "pips"), adopted anyway for a consistent pip figure across every
// instrument on the followed pairs list rather than mixing pips and raw
// price distance in the same alert message.
pipSize() =>
    isJPY    = str.contains(syminfo.ticker, "JPY")
    isXAU    = str.contains(syminfo.ticker, "XAU")
    isCrypto = syminfo.type == "crypto"
    isJPY ? 0.01 : isXAU ? 0.01 : isCrypto ? 1.0 : syminfo.type == "forex" ? 0.0001 : syminfo.mintick

pips(distance) =>
    str.tostring(math.round(math.abs(distance) / pipSize()))

// ---------------- CORE SIGNAL (breakout confirmation gate) ----------------
coreBullTrigger = close > ta.highest(high[1], coreLookback)
coreBearTrigger = close < ta.lowest(low[1], coreLookback)
corePasses = not coreSignalOn or (direction == 1 ? coreBullTrigger : direction == -1 ? coreBearTrigger : false)

// ---------------- ALERT HOURS ----------------
// Gates ONLY the alert()/alertcondition() calls further down — the score,
// badge, table, and drawn entry/SL/TP levels keep updating around the clock
// regardless of this setting.
inSession = alertTimezone == "" ? not na(time(timeframe.period, alertSession)) : not na(time(timeframe.period, alertSession, alertTimezone))
alertsAllowed = not restrictAlertHours or inSession

// ---------------- TRADE STATE FLAGS (declared early for signal gating) ----------------
// These need to exist before newSignal is computed below, since the
// one-trade-at-a-time gate reads inTrade/tp1Hit/slHit. The rest of the trade
// state (entry/SL/TP prices, tradeDir) is declared further down where it's
// first assigned — only the flags needed for gating live here.
var bool inTrade = false
var bool tp1Hit  = false
var bool tp2Hit  = false
var bool tp3Hit  = false
var bool slHit   = false

// While the lock is on, a new signal is only allowed to override the current
// setup once it's already hit TP1 or SL. Note this reads last bar's
// tp1Hit/slHit (they haven't been updated for *this* bar yet — that happens
// in the TP/SL hit detection block further down) so there's a natural
// one-bar lag: override eligibility starts the bar *after* TP1/SL is
// touched, not the same bar. That keeps everything non-repainting.
canOverride = not lockUntilTP1OrSL or not inTrade or tp1Hit or slHit

// ---------------- SIGNAL TRIGGER (fires only on confirmed bar close) ----------------
// lastDir only advances when a signal actually fires (not just when the raw
// score direction flips). That way, if Core Signal is on and the breakout
// hasn't confirmed yet, the script keeps checking on every subsequent bar —
// it doesn't get "stuck" thinking this direction was already handled.
var int lastDir = 0
signalCandidate = barstate.isconfirmed and direction != 0 and direction != lastDir and passesFilter and corePasses and htfTrendOk(direction) and macdOk(direction) and canOverride

// ---------------- S/R FLIP REJECT CONFIRMATION (optional delayed gate) ----------------
// When srGateOn is off, a candidate fires immediately, same as before this
// feature existed. When srGateOn is on, a candidate doesn't fire right away
// — its direction/grade get locked in as "pending," and the actual signal
// only fires once a matching RBS/SBR reject (srSignal, computed in the S/R
// Diagnostics section above) shows up within srConfirmBars bars afterward.
// If the window lapses with no reject, the candidate is dropped silently
// (no signal, no alert, lastDir never advances) — and since lastDir wasn't
// advanced, a fresh pending attempt starts immediately on the next bar as
// long as the underlying conditions still hold, matching the existing
// "keep checking every bar, don't get stuck" philosophy already used for
// lastDir/Core Signal above.
var int    pendingDir   = 0
var string pendingGrade = ""
var int    pendingBar   = na

if signalCandidate and direction != pendingDir
    pendingDir   := direction
    pendingGrade := grade
    pendingBar   := bar_index

// Re-validate the HTF/MACD hard gates every bar while a candidate is
// pending, not just once at the bar it was first noticed. HTF Bias and MACD
// Histogram are each just one of five factors feeding the overall score —
// the score's bull/bear winner (`direction`) can stay unchanged even after
// one of them individually flips against it, if the other factors outweigh
// it. Without this re-check, a candidate queued while HTF was genuinely
// bullish could still fire several bars later after HTF had already flipped
// bearish, silently breaking the "unconditional hard gate" guarantee for
// any signal that spends time waiting on an S/R reject. Confirmed via a
// real case: HTF Bias read -2 (fully bearish) and MACD/ADX/RSI outweighed
// it enough to keep the overall score's direction at +1, so the original
// candidate's own gates no longer held by the time the reject came in —
// this drops the candidate the moment that happens instead of letting it
// fire on stale confluence.
if pendingDir != 0 and not (htfTrendOk(pendingDir) and macdOk(pendingDir))
    pendingDir := 0

srReject   = pendingDir == 1 ? rbsReject : pendingDir == -1 ? sbrReject : false
srConfirmed = srGateOn and pendingDir != 0 and srReject and (bar_index - pendingBar) <= srConfirmBars

// Expire a pending candidate once its window passes without a reject.
if srGateOn and pendingDir != 0 and (bar_index - pendingBar) > srConfirmBars
    pendingDir := 0

// The direction/grade/stars a signal actually fires with — live values when
// the S/R gate is off, the locked-in pending values (from the original
// candidate bar) when it's on, so a signal firing on the later confirmation
// bar can't end up using drifted live values.
signalDir   = srGateOn ? pendingDir   : direction
signalGrade = srGateOn ? pendingGrade : grade
signalStars = starsOf(signalGrade)

newSignal = srGateOn ? srConfirmed : signalCandidate

if newSignal
    lastDir := signalDir
    if srGateOn
        pendingDir := 0

// newSignal (and therefore buySignal/sellSignal) still fires around the
// clock regardless of Alert Hours — the badge/lines/table keep working.
// alertsAllowed only gates whether that signal is also allowed to alert.
buySignal  = newSignal and signalDir == 1 and alertsAllowed
sellSignal = newSignal and signalDir == -1 and alertsAllowed

// alertcondition() must run unconditionally every bar (can't live inside an
// if block) so these show up as pickable conditions in TradingView's
// "Create Alert" dialog, alongside the dynamic alert() message below.
alertcondition(buySignal,               title="Buy Signal",         message="{{ticker}}: BUY signal at {{close}}")
alertcondition(sellSignal,              title="Sell Signal",        message="{{ticker}}: SELL signal at {{close}}")
alertcondition(buySignal or sellSignal, title="Buy or Sell Signal",  message="{{ticker}}: new signal at {{close}}")

// ---------------- TRADE STATE TRACKING ----------------
// (inTrade is declared earlier, alongside the other gating flags.)
var float entryPrice = na
var int   entryBarIndex = na
var float slPrice = na
var float tp1Price = na
var float tp2Price = na
var float tp3Price = na
var int    tradeDir   = 0
var string tradeGrade = ""

// Per-grade win-rate tracking: pure measurement, no effect on signal
// behavior. A "win" is a setup that reached TP1 before ever hitting SL; a
// "loss" is SL hit before TP1 was reached. Indexed by gradeRank(grade) - 1
// (C=0, B=1, A=2, A+=3) so each trade's outcome is tallied against the
// grade it actually entered at, not whatever the live `grade` has drifted
// to by the time the trade resolves.
var int[] gradeWins   = array.new_int(4, 0)
var int[] gradeLosses = array.new_int(4, 0)

gradeWinRateStr(idx) =>
    wins   = array.get(gradeWins, idx)
    losses = array.get(gradeLosses, idx)
    total  = wins + losses
    total == 0 ? "—" : str.tostring(wins) + "/" + str.tostring(total) + " (" + str.tostring(wins / total * 100, "#.0") + "%)"

// Arrays (not single handles) so multiple past setups can be kept on chart
// at once when "Show Previous Setups" is enabled.
var line[]  entryLines = array.new_line()
var line[]  slLines    = array.new_line()
var line[]  tp1Lines   = array.new_line()
var line[]  tp2Lines   = array.new_line()
var line[]  tp3Lines   = array.new_line()
var label[] entryLbls  = array.new_label()
var label[] slLbls     = array.new_label()
var label[] tp1Lbls    = array.new_label()
var label[] tp2Lbls    = array.new_label()
var label[] tp3Lbls    = array.new_label()
var label[] badgeLbls  = array.new_label()
var label[] hitLbls    = array.new_label()

// Drop the oldest setup's drawings to make room, or clear everything if
// history is off (so only the newest setup is ever shown). Entry/SL/TP
// lines, labels, and the small "TP1/TP2/TP3/SL hit" tags are always cleared
// down to just the current setup — only the direction/grade badge persists
// across past setups — so history stays clean instead of piling up old
// price-level and hit-tag clutter.
trimSetups() =>
    keepBadge = showHistory ? maxSetups - 1 : 0
    keepRest  = 0
    while array.size(entryLines) > keepRest
        line.delete(array.shift(entryLines))
    while array.size(slLines) > keepRest
        line.delete(array.shift(slLines))
    while array.size(tp1Lines) > keepRest
        line.delete(array.shift(tp1Lines))
    while array.size(tp2Lines) > keepRest
        line.delete(array.shift(tp2Lines))
    while array.size(tp3Lines) > keepRest
        line.delete(array.shift(tp3Lines))
    while array.size(entryLbls) > keepRest
        label.delete(array.shift(entryLbls))
    while array.size(slLbls) > keepRest
        label.delete(array.shift(slLbls))
    while array.size(tp1Lbls) > keepRest
        label.delete(array.shift(tp1Lbls))
    while array.size(tp2Lbls) > keepRest
        label.delete(array.shift(tp2Lbls))
    while array.size(tp3Lbls) > keepRest
        label.delete(array.shift(tp3Lbls))
    while array.size(hitLbls) > keepRest
        label.delete(array.shift(hitLbls))
    while array.size(badgeLbls) > keepBadge
        label.delete(array.shift(badgeLbls))

// Finds the closest value in `arr` that is (a) on the correct side of
// `ref` ("above" it for a resistance/TP-above search, below it otherwise),
// (b) at least `minGap` beyond `afterLevel` (entry itself for the first
// pick, the previously chosen level for each subsequent one, so TP1 < TP2 <
// TP3 can never end up out of order), and (c) no further than `maxGap` from
// `ref` (so a real-but-distant level doesn't produce an unrealistic stop or
// target). Returns na if nothing qualifies, which the caller falls back to
// the ATR-based distance for.
nearestBeyond(arr, ref, above, afterLevel, minGap, maxGap) =>
    best = float(na)
    for i = 0 to array.size(arr) - 1
        v = array.get(arr, i)
        sideOk = above ? v > ref : v < ref
        gapOk  = above ? v > afterLevel + minGap : v < afterLevel - minGap
        distOk = math.abs(v - ref) <= maxGap
        if sideOk and gapOk and distOk
            if na(best) or (above ? v < best : v > best)
                best := v
    best

// Keeps an ATR-fallback TP from ending up out of order relative to the
// previous level (structural or fallback) it's stacking on top of — e.g. if
// TP1 was a structural level far from entry, a plain ATR-based TP2 could
// otherwise land closer than TP1.
clampBeyond(val, afterLevel, above, minGap) =>
    above ? math.max(val, afterLevel + minGap) : math.min(val, afterLevel - minGap)

if newSignal
    entryPrice    := close
    entryBarIndex := bar_index
    tradeDir      := signalDir
    tradeGrade    := signalGrade
    // volFactor stretches/compresses these ATR distances based on the
    // Low/Normal/High volatility read captured at the moment of entry.
    atrSL  = signalDir == 1 ? close - atrVal * slMult  * volFactor : close + atrVal * slMult  * volFactor
    atrTP1 = signalDir == 1 ? close + atrVal * tp1Mult * volFactor : close - atrVal * tp1Mult * volFactor
    atrTP2 = signalDir == 1 ? close + atrVal * tp2Mult * volFactor : close - atrVal * tp2Mult * volFactor
    atrTP3 = signalDir == 1 ? close + atrVal * tp3Mult * volFactor : close - atrVal * tp3Mult * volFactor

    if useStructureSLTP
        // Structure-based: SL just beyond the nearest swing point behind
        // entry, TP1-3 at the next swing points ahead of entry, each
        // independently falling back to its ATR-based distance whenever no
        // qualifying swing point exists for that specific level.
        minGap = atrVal * srSLTPMinGapMult
        maxGap = atrVal * srSLTPMaxGapMult

        structSL  = signalDir == 1 ? nearestBeyond(swingLows,  close, false, close, minGap, maxGap) : nearestBeyond(swingHighs, close, true,  close, minGap, maxGap)
        slPrice  := na(structSL) ? atrSL : structSL

        structTP1 = signalDir == 1 ? nearestBeyond(swingHighs, close, true,  close, minGap, maxGap) : nearestBeyond(swingLows,  close, false, close, minGap, maxGap)
        tp1Price := na(structTP1) ? atrTP1 : structTP1

        structTP2 = signalDir == 1 ? nearestBeyond(swingHighs, close, true,  tp1Price, minGap, maxGap) : nearestBeyond(swingLows,  close, false, tp1Price, minGap, maxGap)
        tp2Price := na(structTP2) ? clampBeyond(atrTP2, tp1Price, signalDir == 1, minGap) : structTP2

        structTP3 = signalDir == 1 ? nearestBeyond(swingHighs, close, true,  tp2Price, minGap, maxGap) : nearestBeyond(swingLows,  close, false, tp2Price, minGap, maxGap)
        tp3Price := na(structTP3) ? clampBeyond(atrTP3, tp2Price, signalDir == 1, minGap) : structTP3
    else
        slPrice  := atrSL
        tp1Price := atrTP1
        tp2Price := atrTP2
        tp3Price := atrTP3

    inTrade    := true

    trimSetups()

    if showLabels
        // Uses the shared palette so entry/TP/SL stay legible on both light
        // and dark chart themes: neutral (theme-adaptive) TP levels, bear-red
        // SL, accent-blue entry.
        entryCol = palEntry
        tpCol    = palNeutral
        slCol    = palBear

        array.push(entryLines, line.new(bar_index, entryPrice, bar_index + extendBars, entryPrice, color=entryCol, style=line.style_solid,  width=1))
        array.push(slLines,    line.new(bar_index, slPrice,    bar_index + extendBars, slPrice,    color=slCol,    style=line.style_solid,  width=1))
        array.push(tp1Lines,   line.new(bar_index, tp1Price,   bar_index + extendBars, tp1Price,   color=tpCol,    style=line.style_dashed, width=1))
        array.push(tp2Lines,   line.new(bar_index, tp2Price,   bar_index + extendBars, tp2Price,   color=tpCol,    style=line.style_dashed, width=1))
        array.push(tp3Lines,   line.new(bar_index, tp3Price,   bar_index + extendBars, tp3Price,   color=tpCol,    style=line.style_dashed, width=1))

        array.push(entryLbls, label.new(bar_index + extendBars, entryPrice, "ENTRY " + str.tostring(entryPrice, format.mintick), style=label.style_none, textcolor=entryCol, size=size.small, textalign=text.align_left))
        array.push(slLbls,    label.new(bar_index + extendBars, slPrice,  str.tostring(slPrice, format.mintick),  style=label.style_none, textcolor=slCol, size=size.small, textalign=text.align_left))
        array.push(tp1Lbls,   label.new(bar_index + extendBars, tp1Price, "TP1 " + str.tostring(tp1Price, format.mintick), style=label.style_none, textcolor=tpCol, size=size.small, textalign=text.align_left))
        array.push(tp2Lbls,   label.new(bar_index + extendBars, tp2Price, "TP2 " + str.tostring(tp2Price, format.mintick), style=label.style_none, textcolor=tpCol, size=size.small, textalign=text.align_left))
        array.push(tp3Lbls,   label.new(bar_index + extendBars, tp3Price, "TP3 " + str.tostring(tp3Price, format.mintick), style=label.style_none, textcolor=tpCol, size=size.small, textalign=text.align_left))

        // Green/red badge, e.g. "▲ BUY B ★" / "▼ SELL B ★" — spells out the
        // direction so the grade letter (A+/A/B/C) never gets mistaken for
        // a Buy/Sell abbreviation.
        badgeArrow = signalDir == 1 ? "▲" : "▼"
        badgeDir   = signalDir == 1 ? "BUY" : "SELL"
        badgeText  = badgeArrow + " " + badgeDir + " " + signalGrade + " " + signalStars
        badgeCol   = signalDir == 1 ? palBull : palBear
        array.push(badgeLbls, label.new(bar_index, signalDir == 1 ? low : high, badgeText, style=signalDir == 1 ? label.style_label_up : label.style_label_down, color=badgeCol, textcolor=color.white, size=size.small))

    if alertsAllowed
        // Multi-line so the exact levels are readable straight from the
        // notification, without needing to cross-check the chart — useful
        // since the chart's drawn entry/SL/TP can drift slightly from what
        // actually fired if the indicator is later reloaded and Pine
        // recalculates history against a settled (vs. live-streamed) close
        // for that bar. TP3 is intentionally left out: by the time price
        // reaches it, the user should already be watching the chart.
        alertMsg = (signalDir == 1 ? "BUY" : "SELL") + " signal (" + signalGrade + " " + signalStars + ") on " + syminfo.ticker + "\nEntry: " + str.tostring(entryPrice, format.mintick) + "\nTP1: " + str.tostring(tp1Price, format.mintick) + " (" + pips(tp1Price - entryPrice) + " pips)" + "\nTP2: " + str.tostring(tp2Price, format.mintick) + " (" + pips(tp2Price - entryPrice) + " pips)" + "\nSL: " + str.tostring(slPrice, format.mintick) + " (" + pips(slPrice - entryPrice) + " pips)"
        alert(alertMsg, alert.freq_once_per_bar_close)

// ---------------- TP / SL HIT DETECTION & ALERTS ----------------
// (tp1Hit/tp2Hit/tp3Hit/slHit are declared earlier, alongside inTrade.)
if newSignal
    tp1Hit := false
    tp2Hit := false
    tp3Hit := false
    slHit  := false

// Each fires exactly once per level, on the bar that first touches it.
hitTP1 = inTrade and not newSignal and not tp1Hit and (tradeDir == 1 ? high >= tp1Price : low <= tp1Price)
hitTP2 = inTrade and not newSignal and not tp2Hit and (tradeDir == 1 ? high >= tp2Price : low <= tp2Price)
hitTP3 = inTrade and not newSignal and not tp3Hit and (tradeDir == 1 ? high >= tp3Price : low <= tp3Price)
hitSL  = inTrade and not newSignal and not slHit  and (tradeDir == 1 ? low  <= slPrice  : high >= slPrice)

if hitTP1
    tp1Hit := true
    array.set(gradeWins, gradeRank(tradeGrade) - 1, array.get(gradeWins, gradeRank(tradeGrade) - 1) + 1)
    // Move the stop to breakeven now that TP1 has locked in initial profit —
    // moves both the tracked price (so hitSL below checks against the new
    // level) and, if drawn, the actual SL line/label on the chart, so the
    // chart never shows a stale stop that no longer matches reality.
    // Deletes and recreates the line/label (at the original entry bar's x
    // position, so it stays visually aligned) rather than moving them in
    // place with line.set_y1/label.set_text — Pine caps the total number of
    // drawing *modifications* across a script's full history recalculation
    // much lower than the number of objects it allows creating/deleting, and
    // enough historical TP1 hits eventually hit that cap
    // ("modify_study_limit_exceeding"). Delete-then-recreate doesn't count
    // against it.
    slPrice := entryPrice
    if showLabels
        if array.size(slLines) > 0
            line.delete(array.pop(slLines))
            array.push(slLines, line.new(entryBarIndex, slPrice, entryBarIndex + extendBars, slPrice, color=palBear, style=line.style_solid, width=1))
        if array.size(slLbls) > 0
            label.delete(array.pop(slLbls))
            array.push(slLbls, label.new(entryBarIndex + extendBars, slPrice, "BE " + str.tostring(slPrice, format.mintick), style=label.style_none, textcolor=palBear, size=size.small, textalign=text.align_left))
        array.push(hitLbls, label.new(bar_index, tradeDir == 1 ? high : low, "TP1 hit", style=label.style_none, textcolor=palBull, size=size.tiny, yloc=tradeDir == 1 ? yloc.abovebar : yloc.belowbar))
    if alertsAllowed
        alert(syminfo.ticker + ": TP1 hit @ " + str.tostring(tp1Price, format.mintick) + " (+" + pips(tp1Price - entryPrice) + " pips) — stop moved to breakeven (" + str.tostring(slPrice, format.mintick) + ")", alert.freq_once_per_bar_close)

if hitTP2
    tp2Hit := true
    if showLabels
        array.push(hitLbls, label.new(bar_index, tradeDir == 1 ? high : low, "TP2 hit", style=label.style_none, textcolor=palBull, size=size.tiny, yloc=tradeDir == 1 ? yloc.abovebar : yloc.belowbar))
    if alertsAllowed
        alert(syminfo.ticker + ": TP2 hit @ " + str.tostring(tp2Price, format.mintick) + " (+" + pips(tp2Price - entryPrice) + " pips)", alert.freq_once_per_bar_close)

if hitTP3
    tp3Hit := true
    if showLabels
        array.push(hitLbls, label.new(bar_index, tradeDir == 1 ? high : low, "TP3 hit", style=label.style_none, textcolor=palBull, size=size.tiny, yloc=tradeDir == 1 ? yloc.abovebar : yloc.belowbar))
    if alertsAllowed
        alert(syminfo.ticker + ": TP3 hit @ " + str.tostring(tp3Price, format.mintick) + " (+" + pips(tp3Price - entryPrice) + " pips)", alert.freq_once_per_bar_close)

if hitSL
    if not tp1Hit
        array.set(gradeLosses, gradeRank(tradeGrade) - 1, array.get(gradeLosses, gradeRank(tradeGrade) - 1) + 1)
    slHit := true
    // Once TP1 has hit, slPrice has already been moved to breakeven above,
    // so this is no longer a real loss — label/alert wording reflects that
    // instead of saying "SL hit" (which would read as a losing exit).
    hitTag = tp1Hit ? "BE hit" : "SL hit"
    if showLabels
        array.push(hitLbls, label.new(bar_index, tradeDir == 1 ? low : high, hitTag, style=label.style_none, textcolor=palBear, size=size.tiny, yloc=tradeDir == 1 ? yloc.belowbar : yloc.abovebar))
    if alertsAllowed
        alert(syminfo.ticker + ": " + (tp1Hit ? "Breakeven hit @ " : "Stop Loss hit @ ") + str.tostring(slPrice, format.mintick) + " (" + (tp1Hit ? pips(slPrice - entryPrice) : "-" + pips(slPrice - entryPrice)) + " pips)", alert.freq_once_per_bar_close)

// Trade is considered closed once SL is hit, or once TP3 (final target) is hit
// (this happens regardless of Alert Hours — only the alert itself is gated).
if tp3Hit or slHit
    inTrade := false

alertcondition(hitTP1 and alertsAllowed, title="TP1 Hit", message="{{ticker}}: TP1 hit at {{close}}")
alertcondition(hitTP2 and alertsAllowed, title="TP2 Hit", message="{{ticker}}: TP2 hit at {{close}}")
alertcondition(hitTP3 and alertsAllowed, title="TP3 Hit", message="{{ticker}}: TP3 hit at {{close}}")
alertcondition(hitSL  and alertsAllowed, title="Stop Loss Hit", message="{{ticker}}: Stop loss hit at {{close}}")

// ---------------- PLOTTING ----------------
// emaFast/emaSlow are still fully computed above and drive the trend score
// either way — this toggle only controls whether the lines are drawn.
plot(showTrendLines ? emaFast : na, "Fast EMA", color=palEmaFast)
plot(showTrendLines ? emaSlow : na, "Slow EMA", color=palEmaSlow)

// (Signal markers are drawn as the green/red "▲ Grade ★★" badge above, matching
// the reference screenshot's marker style rather than a plain plotshape.)

// ---------------- ENGULFING CANDLE MARKERS (visual aid, no gating) ----------------
// A bullish engulfing candle is a green candle whose body fully swallows the
// prior red candle's body; bearish is the mirror image. Purely a visual aid
// for manually checking the "was there a rejection candle at the zone"
// checklist item — does not feed into scoring, gating, or the S/R confirmation
// logic above (which uses its own reject definition based on wicks/closes
// relative to the zone, not engulfing specifically).
bullEngulfMarker = close[1] < open[1] and close > open and open <= close[1] and close > open[1]
bearEngulfMarker = close[1] > open[1] and close < open and open >= close[1] and close < open[1]
plotshape(srShowEngulf and bullEngulfMarker, title="Bullish Engulfing", style=shape.triangleup,   location=location.belowbar, color=palBull, size=size.tiny)
plotshape(srShowEngulf and bearEngulfMarker, title="Bearish Engulfing", style=shape.triangledown, location=location.abovebar, color=palBear, size=size.tiny)

// ---------------- FACTOR DIAGNOSTICS (Data Window only) ----------------
// Net point contribution (bull minus bear, -2..+2 range) per confluence
// factor, plus the overall score and direction. All display=display.data_window
// — invisible on the chart/price-scale/legend, visible only when hovering a
// bar in TradingView's Data Window. Lets a past signal's grade be explained
// after the fact (e.g. "this B was mostly HTF + RSI, with ADX contributing
// nothing") without changing any scoring, gating, or signal logic.
plot(trendBullPts - trendBearPts, "Diag: Local Trend (pts)",     display=display.data_window)
plot(htfBullPts   - htfBearPts,   "Diag: HTF Bias (pts)",        display=display.data_window)
plot(rsiBullPts   - rsiBearPts,   "Diag: RSI Momentum (pts)",    display=display.data_window)
plot(macdBullPts  - macdBearPts,  "Diag: MACD Histogram (pts)",  display=display.data_window)
plot(adxBullPts   - adxBearPts,   "Diag: ADX/DMI Strength (pts)",display=display.data_window)
plot(score,     "Diag: Score",     display=display.data_window)
plot(direction, "Diag: Direction", display=display.data_window)
plot(srSignal,  "Diag: S/R Flip Reject (1=RBS buy,-1=SBR sell)", display=display.data_window)

// ---------------- INFO TABLE (minimalist) ----------------
// One flat panel tone, no zebra striping, no loud accent colors — just a
// thin adaptive border and a label/value contrast. chart.fg_color/bg_color
// auto-adjust to the user's light/dark chart theme, so this stays legible
// either way instead of being tuned for one theme.
//
// Trimmed down to rows that actually change with the market. Dropped: the
// branding/title row (static text, no market info), Core Signal (a static
// echo of a setting you already configured, not live data), and Alerts
// (only meaningful if Alert Hours is on, and dead weight otherwise). None
// of this touches the underlying logic — Core Signal still gates the
// breakout confirmation and Alert Hours still gates alerts exactly as
// before; they're just no longer displayed in the table.
panelBg  = color.new(chart.fg_color, 95)
labelCol = color.new(chart.fg_color, 40)
valueCol = color.new(chart.fg_color, 0)

if showTable
    var table infoTable = table.new(position.top_right, 2, 6, border_width=1, border_color=color.new(chart.fg_color, 80))

    table.cell(infoTable, 0, 0, inTrade ? "In trade" : "No active trade", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 0, inTrade ? (tradeDir == 1 ? "Long" : "Short") : "—", bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

    // Shows the higher-timeframe bias specifically (not the combined
    // confluence direction) — a standalone "bigger picture" read. Score
    // below already reflects the full 5-factor blend, so this row is
    // deliberately independent of it rather than redundant with it.
    table.cell(infoTable, 0, 1, "Trend (HTF)", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 1, htfBull ? "Bullish" : "Bearish", bgcolor=panelBg, text_color=htfBull ? palBull : palBear, text_halign=text.align_right, text_size=tableSize)

    table.cell(infoTable, 0, 2, "Score", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 2, str.tostring(score, "#.0") + "/10 · " + grade, bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

    table.cell(infoTable, 0, 3, "Momentum", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 3, str.tostring(rsiVal, "#.0"), bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

    table.cell(infoTable, 0, 4, "Trend strength", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 4, str.tostring(adxVal, "#.0") + " · " + (adxStrong ? "Strong" : "Weak"), bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

    table.cell(infoTable, 0, 5, "Volatility", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 5, volState + (useVolScaling ? " · x" + str.tostring(volFactor, "#.00") : ""), bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

// ---------------- GRADE WIN-RATE STATS (pure measurement) ----------------
// Per-grade breakdown of how often a setup reached TP1 before hitting SL vs.
// the reverse. Doesn't affect signal behavior in any way — just a running
// scoreboard so grading quality can be sanity-checked over time. Needs a
// reasonable sample size per grade before the percentages mean much.
if showGradeStats
    var table statsTable = table.new(position.bottom_right, 2, 5, border_width=1, border_color=color.new(chart.fg_color, 80))

    table.cell(statsTable, 0, 0, "Grade", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(statsTable, 1, 0, "TP1 before SL", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_right, text_size=tableSize)

    table.cell(statsTable, 0, 1, "A+", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
