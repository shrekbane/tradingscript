//@version=6
indicator("GradeRunner (Trend+Momentum+Vol+HTF)", shorttitle="GradeRunner", overlay=true, max_lines_count=500, max_labels_count=500)

// =========================================================================
// A from-scratch, independently built confluence/scalping indicator inspired
// by the general concept shown (multi-factor score, graded signal, auto
// entry/SL/3 TPs). This is NOT a copy of any specific author's source code
// (which is private/invite-only and was never seen) - it's a clean-room
// reimplementation of the described mechanics.
// =========================================================================

// ---------------- INPUTS ----------------
grpTrend = "Trend"
fastLen   = input.int(9,  "Fast EMA", group=grpTrend)
slowLen   = input.int(21, "Slow EMA", group=grpTrend)
htfTF     = input.timeframe("60", "Higher Timeframe Bias", group=grpTrend)

grpMom = "Momentum / Strength"
rsiLen   = input.int(14, "RSI Length", group=grpMom)
adxLen   = input.int(14, "ADX / DMI Length", group=grpMom)
macdFast = input.int(12, "MACD Fast", group=grpMom)
macdSlow = input.int(26, "MACD Slow", group=grpMom)
macdSig  = input.int(9,  "MACD Signal", group=grpMom)

grpVol = "Volatility"
atrLen    = input.int(14, "ATR Length", group=grpVol)
atrSmaLen = input.int(50, "ATR Average Length (for Low/Normal/High)", group=grpVol)

grpSignal = "Signal / Risk"
minGradeInput = input.string("B", "Minimum Grade to Show Signal", options=["C","B","A","A+"], group=grpSignal)
slMult  = input.float(1.0, "Stop Loss (x ATR)", step=0.1, group=grpSignal)
tp1Mult = input.float(1.0, "TP1 (x ATR)", step=0.1, group=grpSignal)
tp2Mult = input.float(2.0, "TP2 (x ATR)", step=0.1, group=grpSignal)
tp3Mult = input.float(3.0, "TP3 (x ATR)", step=0.1, group=grpSignal)
extendBars = input.int(20, "Extend Lines (bars)", group=grpSignal)

// Core Signal: an extra, stricter gate on top of the confluence score. The
// score can flip direction purely because a lagging indicator crossed, with
// no real price action behind it. When enabled, a signal additionally needs
// a genuine breakout confirmation — price closing beyond the recent N-bar
// high/low in the signal's direction — before it's allowed to fire. This
// turns the score into a quality/grade filter and Core Signal into the
// actual trigger/timing mechanism.
coreSignalOn  = input.bool(false, "Core Signal (require breakout confirmation)", group=grpSignal)
// v6's active= greys out this input in the settings panel whenever Core
// Signal is off, since it does nothing until that toggle is on.
coreLookback  = input.int(5, "Core Signal Lookback (bars)", minval=1, group=grpSignal, active=coreSignalOn)

// Volatility scaling: SL/TP distances (in ATR multiples) get multiplied by
// one of these depending on the current Low/Normal/High volatility read, so
// stops/targets widen automatically when the market's noisier and tighten
// when it's calmer, instead of using one fixed distance regardless of
// conditions.
useVolScaling = input.bool(true, "Scale SL/TP by Volatility", group=grpSignal)
lowVolFactor  = input.float(0.75, "Low Volatility Multiplier",  step=0.05, group=grpSignal, active=useVolScaling)
highVolFactor = input.float(1.5,  "High Volatility Multiplier", step=0.05, group=grpSignal, active=useVolScaling)

// One-trade-at-a-time gate: while ON (default), a new signal can only
// override the currently tracked setup once that setup has hit TP1 (locked
// in first profit) or SL (stopped out). Before that point, new signals are
// simply ignored and the ongoing trade is left to run toward TP2/TP3. While
// OFF, any qualifying signal always overrides immediately, regardless of
// how far the current trade has progressed (the original behavior).
lockUntilTP1OrSL = input.bool(true, "Lock New Signals Until TP1 or SL Hit", group=grpSignal)

// Confirmed-close stop loss: a sharp pullback right after entry can wick
// through the SL intrabar and immediately reverse, stopping the trade out
// on noise rather than a genuine breakdown. With this on, the SL only
// counts as hit once a bar actually CLOSES beyond it (checked on confirmed
// bars only) instead of the instant a wick touches it. Trade-off: on a
// real breakdown, the exit confirms one bar later, so the realized loss
// can run a little past the displayed SL. TP1/TP2/TP3 are deliberately
// unaffected — profit-taking still triggers the instant price touches a
// target, since eagerly locking in gains carries the opposite risk.
confirmCloseSL = input.bool(true, "Require Confirmed Close for Stop Loss", group=grpSignal)

// Pullback entry: instead of entering the instant the score/filters
// qualify, this waits for price to retrace against the signal by a
// configurable ATR amount (the "pullback"), then only confirms entry once
// price closes back in the signal's favor beyond that pullback's extreme
// (the "resumption"). This avoids entering right before a hard pullback
// that could shake out the stop before the move actually gets going. A
// qualifying signal "arms" a pending entry rather than firing immediately;
// if the pullback + resumption doesn't complete within the timeout, the
// pending entry is abandoned and a fresh qualifying signal is needed to
// try again. On by default so new users get the more conservative entry
// behavior out of the box, without needing to find and enable it first.
usePullbackEntry = input.bool(true, "Wait for Pullback Before Entry", group=grpSignal)
pullbackAtrMult  = input.float(0.5, "Pullback Depth (x ATR)", step=0.05, minval=0.05, group=grpSignal, active=usePullbackEntry)
pullbackMaxBars  = input.int(10, "Max Bars to Wait for Pullback", minval=1, group=grpSignal, active=usePullbackEntry)

// Alert Hours: restricts when alert()/alertcondition() are allowed to fire —
// e.g. skip the Asian session, or only alert during your own trading hours.
// This only gates alerts. The score, badge, table, and drawn levels keep
// updating normally around the clock; nothing here suppresses the chart.
grpHours = "Alert Hours"
restrictAlertHours = input.bool(false, "Only Alert During Selected Hours", group=grpHours)
// input.session() opens TradingView's own session picker, which includes a
// day-of-week selector — no separate "which days" input needed.
alertSession = input.session("0900-1700", "Trading Hours (session)", group=grpHours, active=restrictAlertHours)

// Dropdown instead of free text — most people don't know their IANA
// timezone string off the top of their head. "Exchange (default)" maps to
// blank, which tells time() to use the chart symbol's own exchange timezone.
// Note: input.string()'s options list must be written inline like this —
// Pine doesn't allow assigning the [...] literal to a variable first.
alertTimezoneSel = input.string("Exchange (default)", "Timezone", options=["Exchange (default)", "UTC", "New York (UTC-5/-4)", "Chicago (UTC-6/-5)", "Los Angeles (UTC-8/-7)", "Sao Paulo (UTC-3)", "London (UTC+0/+1)", "Paris / Frankfurt (UTC+1/+2)", "Moscow (UTC+3)", "Dubai (UTC+4)", "Mumbai (UTC+5:30)", "Singapore (UTC+8)", "Hong Kong (UTC+8)", "Shanghai (UTC+8)", "Tokyo (UTC+9)", "Sydney (UTC+10/+11)", "Auckland (UTC+12/+13)"], group=grpHours, active=restrictAlertHours)

tzToIANA(sel) =>
    sel == "UTC" ? "UTC" :
     sel == "New York (UTC-5/-4)" ? "America/New_York" :
     sel == "Chicago (UTC-6/-5)" ? "America/Chicago" :
     sel == "Los Angeles (UTC-8/-7)" ? "America/Los_Angeles" :
     sel == "Sao Paulo (UTC-3)" ? "America/Sao_Paulo" :
     sel == "London (UTC+0/+1)" ? "Europe/London" :
     sel == "Paris / Frankfurt (UTC+1/+2)" ? "Europe/Paris" :
     sel == "Moscow (UTC+3)" ? "Europe/Moscow" :
     sel == "Dubai (UTC+4)" ? "Asia/Dubai" :
     sel == "Mumbai (UTC+5:30)" ? "Asia/Kolkata" :
     sel == "Singapore (UTC+8)" ? "Asia/Singapore" :
     sel == "Hong Kong (UTC+8)" ? "Asia/Hong_Kong" :
     sel == "Shanghai (UTC+8)" ? "Asia/Shanghai" :
     sel == "Tokyo (UTC+9)" ? "Asia/Tokyo" :
     sel == "Sydney (UTC+10/+11)" ? "Australia/Sydney" :
     sel == "Auckland (UTC+12/+13)" ? "Pacific/Auckland" :
     "" // "Exchange (default)" falls through to blank

alertTimezone = tzToIANA(alertTimezoneSel)

grpTable = "Display"
showTable = input.bool(true, "Show Info Table", group=grpTable)
// Lets phone/small-screen users shrink the table instead of being stuck
// with a size tuned for desktop charts.
tableSizeInput = input.string("Small", "Table Text Size", options=["Tiny", "Small", "Normal", "Large"], group=grpTable, active=showTable)
showLabels = input.bool(true, "Show Signal Markers", group=grpTable)
showTrendLines = input.bool(false, "Show Trend (EMA) Lines", group=grpTable)
showHistory = input.bool(false, "Show Previous Setups (keep history)", group=grpTable)
maxSetups   = input.int(5, "Max Setups to Keep (if history on)", minval=1, maxval=40, group=grpTable, active=showHistory)

tableTextSize(sel) =>
    sel == "Tiny" ? size.tiny : sel == "Normal" ? size.normal : sel == "Large" ? size.large : size.small
tableSize = tableTextSize(tableSizeInput)

// ---------------- COLOR PALETTE (light/dark theme safe) ----------------
// One shared palette used everywhere on the chart, chosen so every color
// keeps decent contrast whether the chart theme is light or dark:
// - palBull/palBear: mid-brightness teal/red (similar family to TradingView's
//   own up/down candle colors) rather than pure color.green/color.red or a
//   very dark maroon, which can wash out or vanish depending on theme.
// - palNeutral: derived from chart.fg_color, so it's automatically near-black
//   on a light chart and near-white on a dark chart — used for the TP levels,
//   which should read as "neutral text," not bullish or bearish.
// - palEntry: a bright, saturated blue that holds contrast on both themes.
// - palEmaFast/palEmaSlow: mid-tone amber/violet for the optional EMA lines.
palBull    = color.new(#26A69A, 0)
palBear    = color.new(#EF5350, 0)
palEntry   = color.new(#2962FF, 0)
palNeutral = color.new(chart.fg_color, 0)
palEmaFast = color.new(#FFB300, 0)
palEmaSlow = color.new(#8E24AA, 0)

// ---------------- TREND ----------------
emaFast = ta.ema(close, fastLen)
emaSlow = ta.ema(close, slowLen)
trendBull = emaFast > emaSlow

// Higher timeframe bias (confirmed HTF bars only -> no intrabar repaint).
// Both EMAs are fetched in a single request.security() call (tuple return)
// instead of two separate calls — fewer security requests, and guarantees
// both series come from the exact same HTF bar.
[htfEmaFast, htfEmaSlow] = request.security(syminfo.tickerid, htfTF, [ta.ema(close, fastLen), ta.ema(close, slowLen)], lookahead=barmerge.lookahead_off)
htfBull = htfEmaFast > htfEmaSlow

// ---------------- MOMENTUM ----------------
rsiVal = ta.rsi(close, rsiLen)
// Only the histogram is used for scoring — macdLine/macdSignal are discarded
// via `_` placeholders rather than named and left unused.
[_, _, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)

// ---------------- TREND STRENGTH (DMI/ADX) ----------------
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
adxStrong = adxVal > 20
diBull = diPlus > diMinus

// ---------------- VOLATILITY ----------------
atrVal    = ta.atr(atrLen)
atrAvg    = ta.sma(atrVal, atrSmaLen)
volRatio  = atrVal / atrAvg
volState  = volRatio >= 1.2 ? "High" : volRatio <= 0.8 ? "Low" : "Normal"

// Multiplier applied on top of the SL/TP ATR multiples below, based on volState.
volFactor = not useVolScaling ? 1.0 : volState == "High" ? highVolFactor : volState == "Low" ? lowVolFactor : 1.0

// ---------------- CONFLUENCE SCORE (0-10, split bull/bear) ----------------
bullPts = 0.0
bearPts = 0.0

// 1) Local trend (2 pts)
bullPts += trendBull ? 2.0 : 0.0
bearPts += trendBull ? 0.0 : 2.0

// 2) HTF bias (2 pts)
bullPts += htfBull ? 2.0 : 0.0
bearPts += htfBull ? 0.0 : 2.0

// 3) RSI momentum (up to 2 pts, scaled by distance from 50)
rsiBullPts = rsiVal > 50 ? math.min((rsiVal - 50) / 25 * 2, 2.0) : 0.0
rsiBearPts = rsiVal < 50 ? math.min((50 - rsiVal) / 25 * 2, 2.0) : 0.0
bullPts += rsiBullPts
bearPts += rsiBearPts

// 4) MACD histogram direction (2 pts)
bullPts += macdHist > 0 ? 2.0 : 0.0
bearPts += macdHist > 0 ? 0.0 : 2.0

// 5) ADX/DMI strength confirmation (2 pts, only if trend is strong)
if adxStrong
    bullPts += diBull ? 2.0 : 0.0
    bearPts += diBull ? 0.0 : 2.0

score     = math.max(bullPts, bearPts)
direction = bullPts > bearPts ? 1 : bullPts < bearPts ? -1 : 0

gradeOf(s) =>
    s >= 9.0 ? "A+" : s >= 7.0 ? "A" : s >= 5.0 ? "B" : "C"

grade = gradeOf(score)

gradeRank(g) => g == "A+" ? 4 : g == "A" ? 3 : g == "B" ? 2 : 1
passesFilter = gradeRank(grade) >= gradeRank(minGradeInput)

starsOf(g) =>
    g == "A+" ? "★★★" : g == "A" ? "★★" : g == "B" ? "★" : ""
stars = starsOf(grade)

// ---------------- CORE SIGNAL (breakout confirmation gate) ----------------
coreBullTrigger = close > ta.highest(high[1], coreLookback)
coreBearTrigger = close < ta.lowest(low[1], coreLookback)
corePasses = not coreSignalOn or (direction == 1 ? coreBullTrigger : direction == -1 ? coreBearTrigger : false)

// ---------------- ALERT HOURS ----------------
// Gates ONLY the alert()/alertcondition() calls further down — the score,
// badge, table, and drawn entry/SL/TP levels keep updating around the clock
// regardless of this setting.
inSession = alertTimezone == "" ? not na(time(timeframe.period, alertSession)) : not na(time(timeframe.period, alertSession, alertTimezone))
alertsAllowed = not restrictAlertHours or inSession

// ---------------- TRADE STATE FLAGS (declared early for signal gating) ----------------
// These need to exist before newSignal is computed below, since the
// one-trade-at-a-time gate reads inTrade/tp1Hit/slHit. The rest of the trade
// state (entry/SL/TP prices, tradeDir) is declared further down where it's
// first assigned — only the flags needed for gating live here.
var bool inTrade = false
var bool tp1Hit  = false
var bool tp2Hit  = false
var bool tp3Hit  = false
var bool slHit   = false

// While the lock is on, a new signal is only allowed to override the current
// setup once it's already hit TP1 or SL. Note this reads last bar's
// tp1Hit/slHit (they haven't been updated for *this* bar yet — that happens
// in the TP/SL hit detection block further down) so there's a natural
// one-bar lag: override eligibility starts the bar *after* TP1/SL is
// touched, not the same bar. That keeps everything non-repainting.
canOverride = not lockUntilTP1OrSL or not inTrade or tp1Hit or slHit

// ---------------- SIGNAL TRIGGER (fires only on confirmed bar close) ----------------
// lastDir only advances when a signal actually fires (not just when the raw
// score direction flips, and not just when a pullback entry arms). That
// way, if Core Signal is on and the breakout hasn't confirmed yet — or if
// Pullback Entry is on and still waiting — the script keeps checking on
// every subsequent bar instead of getting "stuck" thinking this direction
// was already handled.
var int lastDir = 0
rawQualifies = barstate.isconfirmed and direction != 0 and direction != lastDir and passesFilter and corePasses and canOverride

// Pullback Entry state (persists across bars while a signal is "armed" and
// waiting for its pullback + resumption).
var bool  pending         = false
var int   pendingDir      = 0
var float pendingExtreme  = na   // best price reached in pendingDir's favor since arming
var float pullbackExtreme = na   // worst price reached during the pullback itself; na until a pullback is confirmed
var int   pendingBars     = 0

newSignal = false
entryDir  = 0

if not usePullbackEntry
    // Original behavior, unchanged: fire immediately when qualified.
    newSignal := rawQualifies
    entryDir  := direction
else
    // If the score reverses against an armed entry, abandon it — the setup
    // that was being waited on no longer holds. Gated to confirmed bars
    // only: direction recalculates every tick intrabar, so without this,
    // a brief intrabar flicker could permanently cancel a waiting setup
    // even if the score flips back by the time the bar actually closes.
    if pending and barstate.isconfirmed and direction != 0 and direction != pendingDir
        pending := false
        pendingExtreme := na
        pullbackExtreme := na
        pendingBars := 0

    justArmed = false
    if not pending and rawQualifies
        pending := true
        pendingDir := direction
        pendingExtreme := direction == 1 ? high : low
        pullbackExtreme := na
        pendingBars := 0
        justArmed := true

    // Process an existing pending arm starting the bar *after* it armed —
    // confirmed bars only, so this stays non-repainting.
    if pending and not justArmed and barstate.isconfirmed
        pendingBars += 1
        pendingExtreme := pendingDir == 1 ? math.max(pendingExtreme, high) : math.min(pendingExtreme, low)

        if na(pullbackExtreme)
            retr = pendingDir == 1 ? pendingExtreme - low : high - pendingExtreme
            if retr >= pullbackAtrMult * atrVal
                pullbackExtreme := pendingDir == 1 ? low : high
        else
            pullbackExtreme := pendingDir == 1 ? math.min(pullbackExtreme, low) : math.max(pullbackExtreme, high)

        // Re-check the grade filter here too, not just at arming — the
        // score keeps recalculating every bar while a signal waits for its
        // pullback + resumption, so the grade that qualified it at arming
        // time can drift below the minimum by the time price actually
        // resumes. Without this check, a since-degraded setup could still
        // fire and display whatever grade it happened to be at that later
        // bar, silently ignoring the Minimum Grade setting.
        resumed = not na(pullbackExtreme) and (pendingDir == 1 ? close > pullbackExtreme : close < pullbackExtreme) and passesFilter

        if resumed
            newSignal := true
            entryDir  := pendingDir
            pending := false
            pendingExtreme := na
            pullbackExtreme := na
            pendingBars := 0
        else if pendingBars >= pullbackMaxBars
            // Gave up waiting — a fresh qualifying signal is needed to try again.
            pending := false
            pendingExtreme := na
            pullbackExtreme := na
            pendingBars := 0

if newSignal
    lastDir := entryDir

// newSignal (and therefore buySignal/sellSignal) still fires around the
// clock regardless of Alert Hours — the badge/lines/table keep working.
// alertsAllowed only gates whether that signal is also allowed to alert.
buySignal  = newSignal and entryDir == 1 and alertsAllowed
sellSignal = newSignal and entryDir == -1 and alertsAllowed

// alertcondition() must run unconditionally every bar (can't live inside an
// if block) so these show up as pickable conditions in TradingView's
// "Create Alert" dialog, alongside the dynamic alert() message below.
alertcondition(buySignal,               title="Buy Signal",         message="{{ticker}}: BUY signal at {{close}}")
alertcondition(sellSignal,              title="Sell Signal",        message="{{ticker}}: SELL signal at {{close}}")
alertcondition(buySignal or sellSignal, title="Buy or Sell Signal",  message="{{ticker}}: new signal at {{close}}")

// ---------------- TRADE STATE TRACKING ----------------
// (inTrade is declared earlier, alongside the other gating flags.)
var float entryPrice = na
var float slPrice = na
var float tp1Price = na
var float tp2Price = na
var float tp3Price = na
var int   tradeDir = 0

// The entry/SL/TP1-3 lines and labels only ever have ONE live instance at a
// time — the current setup. The old array-based version pushed each new one
// onto an array and then immediately trimmed it back down to 0 elements, on
// every single signal. Arrays were the wrong tool for something that never
// actually holds more than one item: a single mutable object (Setup) whose
// old drawings get deleted and replaced does the same job more directly.
// Only the badge (genuinely keeps multiple past entries when "Show Previous
// Setups" is on) and the hit tags (2-3 can be alive at once mid-trade,
// e.g. TP1 hit + TP2 hit before TP3/SL closes the setup) actually need arrays.
type Setup
    line  entryLine
    line  slLine
    line  tp1Line
    line  tp2Line
    line  tp3Line
    label entryLbl
    label slLbl
    label tp1Lbl
    label tp2Lbl
    label tp3Lbl

var cur = Setup.new()

var label[] badgeLbls = array.new_label()
var label[] hitLbls   = array.new_label()

// Shared by trimSetups() below — deletes down to `keep` elements from the
// front of a label array. Arrays are reference types in Pine, so mutating
// `arr` here mutates the caller's actual array.
trimLabels(arr, keep) =>
    while array.size(arr) > keep
        label.delete(array.shift(arr))

// Deletes the previous setup's entry/SL/TP drawings, if any exist, so the
// next setup can draw fresh ones in their place.
clearCurrentSetup() =>
    if not na(cur.entryLine)
        line.delete(cur.entryLine)
        line.delete(cur.slLine)
        line.delete(cur.tp1Line)
        line.delete(cur.tp2Line)
        line.delete(cur.tp3Line)
        label.delete(cur.entryLbl)
        label.delete(cur.slLbl)
        label.delete(cur.tp1Lbl)
        label.delete(cur.tp2Lbl)
        label.delete(cur.tp3Lbl)

trimSetups() =>
    keepBadge = showHistory ? maxSetups - 1 : 0
    clearCurrentSetup()
    trimLabels(hitLbls, 0)
    trimLabels(badgeLbls, keepBadge)

if newSignal
    // entryDir is this entry's direction — same as the live score direction
    // when Pullback Entry is off, or the direction it was originally armed
    // in when waiting for a pullback + resumption (which may differ from
    // whatever the live score is doing by the time resumption confirms).
    entryPrice := close
    tradeDir   := entryDir
    // volFactor stretches/compresses these ATR distances based on the
    // Low/Normal/High volatility read captured at the moment of entry.
    slPrice    := entryDir == 1 ? close - atrVal * slMult  * volFactor : close + atrVal * slMult  * volFactor
    tp1Price   := entryDir == 1 ? close + atrVal * tp1Mult * volFactor : close - atrVal * tp1Mult * volFactor
    tp2Price   := entryDir == 1 ? close + atrVal * tp2Mult * volFactor : close - atrVal * tp2Mult * volFactor
    tp3Price   := entryDir == 1 ? close + atrVal * tp3Mult * volFactor : close - atrVal * tp3Mult * volFactor
    inTrade    := true

    trimSetups()

    if showLabels
        // Uses the shared palette so entry/TP/SL stay legible on both light
        // and dark chart themes: neutral (theme-adaptive) TP levels, bear-red
        // SL, accent-blue entry.
        entryCol = palEntry
        tpCol    = palNeutral
        slCol    = palBear

        cur.entryLine := line.new(bar_index, entryPrice, bar_index + extendBars, entryPrice, color=entryCol, style=line.style_solid,  width=1)
        cur.slLine    := line.new(bar_index, slPrice,    bar_index + extendBars, slPrice,    color=slCol,    style=line.style_solid,  width=1)
        cur.tp1Line   := line.new(bar_index, tp1Price,   bar_index + extendBars, tp1Price,   color=tpCol,    style=line.style_dashed, width=1)
        cur.tp2Line   := line.new(bar_index, tp2Price,   bar_index + extendBars, tp2Price,   color=tpCol,    style=line.style_dashed, width=1)
        cur.tp3Line   := line.new(bar_index, tp3Price,   bar_index + extendBars, tp3Price,   color=tpCol,    style=line.style_dashed, width=1)

        cur.entryLbl := label.new(bar_index + extendBars, entryPrice, "ENTRY " + str.tostring(entryPrice, format.mintick), style=label.style_none, textcolor=entryCol, size=size.small, textalign=text.align_left)
        cur.slLbl    := label.new(bar_index + extendBars, slPrice,  str.tostring(slPrice, format.mintick),  style=label.style_none, textcolor=slCol, size=size.small, textalign=text.align_left)
        cur.tp1Lbl   := label.new(bar_index + extendBars, tp1Price, "TP1 " + str.tostring(tp1Price, format.mintick), style=label.style_none, textcolor=tpCol, size=size.small, textalign=text.align_left)
        cur.tp2Lbl   := label.new(bar_index + extendBars, tp2Price, "TP2 " + str.tostring(tp2Price, format.mintick), style=label.style_none, textcolor=tpCol, size=size.small, textalign=text.align_left)
        cur.tp3Lbl   := label.new(bar_index + extendBars, tp3Price, "TP3 " + str.tostring(tp3Price, format.mintick), style=label.style_none, textcolor=tpCol, size=size.small, textalign=text.align_left)

        // Green/red badge, e.g. "▲ BUY B ★" / "▼ SELL B ★" — spells out the
        // direction so the grade letter (A+/A/B/C) never gets mistaken for
        // a Buy/Sell abbreviation.
        badgeArrow = entryDir == 1 ? "▲" : "▼"
        badgeDir   = entryDir == 1 ? "BUY" : "SELL"
        badgeText  = badgeArrow + " " + badgeDir + " " + grade + " " + stars
        badgeCol   = entryDir == 1 ? palBull : palBear
        array.push(badgeLbls, label.new(bar_index, entryDir == 1 ? low : high, badgeText, style=entryDir == 1 ? label.style_label_up : label.style_label_down, color=badgeCol, textcolor=color.white, size=size.small))

    if alertsAllowed
        // Multi-line message: header (direction/grade/ticker) followed by
        // Entry/TP1/TP2/SL, one per line. TP3 is deliberately left out — by
        // the time price is that far along, the user should already be
        // watching the chart to manage it, so it doesn't need to be in the
        // initial entry alert.
        alertHeader = (entryDir == 1 ? "BUY signal (" : "SELL signal (") + grade + " " + stars + ") on " + syminfo.ticker
        alertMsg = alertHeader + "\n" +
                     "Entry: " + str.tostring(entryPrice, format.mintick) + "\n" +
                     "TP1: " + str.tostring(tp1Price, format.mintick) + "\n" +
                     "TP2: " + str.tostring(tp2Price, format.mintick) + "\n" +
                     "SL: " + str.tostring(slPrice, format.mintick)
        alert(alertMsg, alert.freq_once_per_bar_close)

// ---------------- TP / SL HIT DETECTION & ALERTS ----------------
// (tp1Hit/tp2Hit/tp3Hit/slHit are declared earlier, alongside inTrade.)
if newSignal
    tp1Hit := false
    tp2Hit := false
    tp3Hit := false
    slHit  := false

// Each fires exactly once per level, on the bar that first touches it.
// TPs stay wick-based/intrabar on purpose — locking in profit the instant
// price touches a target is the safer side to be eager on.
hitTP1 = inTrade and not newSignal and not tp1Hit and (tradeDir == 1 ? high >= tp1Price : low <= tp1Price)
hitTP2 = inTrade and not newSignal and not tp2Hit and (tradeDir == 1 ? high >= tp2Price : low <= tp2Price)
hitTP3 = inTrade and not newSignal and not tp3Hit and (tradeDir == 1 ? high >= tp3Price : low <= tp3Price)

// SL condition depends on confirmCloseSL: either a confirmed bar closing
// beyond the stop, or the original instant wick-touch check.
slCondition = confirmCloseSL ?
                 (barstate.isconfirmed and (tradeDir == 1 ? close <= slPrice : close >= slPrice)) :
                 (tradeDir == 1 ? low <= slPrice : high >= slPrice)
hitSL = inTrade and not newSignal and not slHit and slCondition

// Shared by the four blocks below — pushes the "<level> hit" tag (if
// enabled) and fires the alert (if allowed). isTP flips which side of the
// bar the tag sits on: TP tags sit on the "profit" side, SL tags sit on the
// opposite side.
fireHit(labelText, alertText, price, col, isTP) =>
    if showLabels
        yVal   = isTP ? (tradeDir == 1 ? high : low) : (tradeDir == 1 ? low : high)
        yPlace = isTP ? (tradeDir == 1 ? yloc.abovebar : yloc.belowbar) : (tradeDir == 1 ? yloc.belowbar : yloc.abovebar)
        array.push(hitLbls, label.new(bar_index, yVal, labelText, style=label.style_none, textcolor=col, size=size.tiny, yloc=yPlace))
    if alertsAllowed
        alert(syminfo.ticker + ": " + alertText + " @ " + str.tostring(price, format.mintick), alert.freq_once_per_bar_close)

if hitTP1
    tp1Hit := true
    fireHit("TP1 hit", "TP1 hit", tp1Price, palBull, true)

if hitTP2
    tp2Hit := true
    fireHit("TP2 hit", "TP2 hit", tp2Price, palBull, true)

if hitTP3
    tp3Hit := true
    fireHit("TP3 hit", "TP3 hit", tp3Price, palBull, true)

if hitSL
    slHit := true
    fireHit("SL hit", "Stop Loss hit", slPrice, palBear, false)

// Trade is considered closed once SL is hit, or once TP3 (final target) is hit
// (this happens regardless of Alert Hours — only the alert itself is gated).
if tp3Hit or slHit
    inTrade := false

alertcondition(hitTP1 and alertsAllowed, title="TP1 Hit", message="{{ticker}}: TP1 hit at {{close}}")
alertcondition(hitTP2 and alertsAllowed, title="TP2 Hit", message="{{ticker}}: TP2 hit at {{close}}")
alertcondition(hitTP3 and alertsAllowed, title="TP3 Hit", message="{{ticker}}: TP3 hit at {{close}}")
alertcondition(hitSL  and alertsAllowed, title="Stop Loss Hit", message="{{ticker}}: Stop loss hit at {{close}}")

// ---------------- PLOTTING ----------------
// emaFast/emaSlow are still fully computed above and drive the trend score
// either way — this toggle only controls whether the lines are drawn.
plot(showTrendLines ? emaFast : na, "Fast EMA", color=palEmaFast)
plot(showTrendLines ? emaSlow : na, "Slow EMA", color=palEmaSlow)

// (Signal markers are drawn as the green/red "▲ Grade ★★" badge above, matching
// the reference screenshot's marker style rather than a plain plotshape.)

// ---------------- INFO TABLE (minimalist) ----------------
// One flat panel tone, no zebra striping, no loud accent colors — just a
// thin adaptive border and a label/value contrast. chart.fg_color/bg_color
// auto-adjust to the user's light/dark chart theme, so this stays legible
// either way instead of being tuned for one theme.
//
// Trimmed down to rows that actually change with the market. Dropped: the
// branding/title row (static text, no market info), Core Signal (a static
// echo of a setting you already configured, not live data), and Alerts
// (only meaningful if Alert Hours is on, and dead weight otherwise). None
// of this touches the underlying logic — Core Signal still gates the
// breakout confirmation and Alert Hours still gates alerts exactly as
// before; they're just no longer displayed in the table.
// barstate.islast: the table only ever shows the latest state, so there's no
// need to rewrite its cells on every historical bar — only on the current one.
if showTable and barstate.islast
    var table infoTable = table.new(position.top_right, 2, 6, border_width=1, border_color=color.new(chart.fg_color, 80))
    panelBg  = color.new(chart.fg_color, 95)
    labelCol = color.new(chart.fg_color, 40)
    valueCol = color.new(chart.fg_color, 0)

    table.cell(infoTable, 0, 0, inTrade ? "In trade" : "No active trade", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 0, inTrade ? (tradeDir == 1 ? "Long" : "Short") : "—", bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

    // Shows the higher-timeframe bias specifically (not the combined
    // confluence direction) — a standalone "bigger picture" read. Score
    // below already reflects the full 5-factor blend, so this row is
    // deliberately independent of it rather than redundant with it.
    table.cell(infoTable, 0, 1, "Trend (HTF)", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 1, htfBull ? "Bullish" : "Bearish", bgcolor=panelBg, text_color=htfBull ? palBull : palBear, text_halign=text.align_right, text_size=tableSize)

    table.cell(infoTable, 0, 2, "Score", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 2, str.tostring(score, "#.0") + "/10 · " + grade, bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

    table.cell(infoTable, 0, 3, "Momentum", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 3, str.tostring(rsiVal, "#.0"), bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

    table.cell(infoTable, 0, 4, "Trend strength", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 4, str.tostring(adxVal, "#.0") + " · " + (adxStrong ? "Strong" : "Weak"), bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)

    table.cell(infoTable, 0, 5, "Volatility", bgcolor=panelBg, text_color=labelCol, text_halign=text.align_left, text_size=tableSize)
    table.cell(infoTable, 1, 5, volState + (useVolScaling ? " · x" + str.tostring(volFactor, "#.00") : ""), bgcolor=panelBg, text_color=valueCol, text_halign=text.align_right, text_size=tableSize)
